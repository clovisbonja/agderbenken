# ═══════════════════════════════════════════════════════════════
# MILJØVARIABLER — Sørblikket
# ═══════════════════════════════════════════════════════════════
#
# Kopier denne filen til .env.local og fyll inn dine egne verdier:
#   cp .env.example .env.local
#
# .env.local er gitignored og skal ALDRI commites til git.
#
# ── SUPABASE (valgfritt) ──────────────────────────────────────
#
# Brukes kun for valgløfte-fanen på Parti-siden.
# Uten disse variablene fungerer hele appen, men valgløfter
# vises ikke.
#
# Finn verdiene i Supabase-dashbordet:
# → https://supabase.com/dashboard → ditt prosjekt
# → Project Settings → API
#
VITE_SUPABASE_URL=https://ditt-prosjekt-id.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-public-key-her
